# API Keys (model/pricing config is in config/llm_providers.yaml)
GOOGLE_API_KEY=your-google-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

APP_DEBUG=true

# --- Channel: Microsoft Teams ---
# See docs/channel-setup.md for how to obtain these values
APP_TEAMS_ENABLED=false
APP_TEAMS_APP_ID=                          # Azure Bot App ID (GUID)
APP_TEAMS_APP_PASSWORD=                    # Azure App Registration client secret
APP_TEAMS_SERVICE_URL=https://smba.trafficmanager.net/emea/   # EMEA | amer | apac
APP_TEAMS_DEFAULT_CONVERSATION_ID=         # Teams conversation ID for proactive messages

# --- Channel: WhatsApp (Twilio) ---
# See docs/channel-setup.md for how to obtain these values
APP_WHATSAPP_ENABLED=false
APP_WHATSAPP_ACCOUNT_SID=                  # Twilio Account SID (starts with AC)
APP_WHATSAPP_AUTH_TOKEN=                   # Twilio Auth Token
APP_WHATSAPP_FROM_NUMBER=                  # Sender phone number (E.164, e.g. +14155238886)
APP_WHATSAPP_ALLOWED_NUMBERS=[]            # JSON array of allowed numbers, e.g. ["+36301234567"]
