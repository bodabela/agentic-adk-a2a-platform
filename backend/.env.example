# =============================================================================
# backend/.env — Local development WITHOUT Docker.
# When running via Docker Compose, use the ROOT .env instead (../.env).
# Copy to .env and fill in your values.
# =============================================================================

# --- API Keys (model/pricing config is in config/llm_providers.yaml) ---
GOOGLE_API_KEY=your-google-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# --- App ---
APP_DEBUG=true
APP_PROJECT=personal_assistant
# APP_DEFAULT_MODEL=gemini-2.0-flash
# APP_FALLBACK_MODEL=gemini-1.5-pro

# --- Channel: Microsoft Teams ---
# See docs/channel-setup.md for how to obtain these values
APP_TEAMS_ENABLED=false
APP_TEAMS_APP_ID=
APP_TEAMS_APP_PASSWORD=
APP_TEAMS_SERVICE_URL=https://smba.trafficmanager.net/emea/
APP_TEAMS_DEFAULT_CONVERSATION_ID=

# --- Channel: WhatsApp (Twilio) ---
# See docs/channel-setup.md for how to obtain these values
APP_WHATSAPP_ENABLED=false
APP_WHATSAPP_ACCOUNT_SID=
APP_WHATSAPP_AUTH_TOKEN=
APP_WHATSAPP_FROM_NUMBER=
APP_WHATSAPP_ALLOWED_NUMBERS=[]

# --- Tracing / Observability ---
APP_TRACING_ENABLED=true
APP_OTLP_ENDPOINT=http://localhost:4317

# --- Langfuse (LLM Observability) ---
# Create keys at http://localhost:3001 → Settings → API Keys
APP_LANGFUSE_ENABLED=false
APP_LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PROJECT_ID=
