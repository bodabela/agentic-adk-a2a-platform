[
  {
    "beginRendering": {
      "surfaceId": "choice",
      "root": "root-column",
      "styles": {"primaryColor": "#1976D2", "font": "Roboto"}
    }
  },
  {
    "surfaceUpdate": {
      "surfaceId": "choice",
      "components": [
        {
          "id": "root-column",
          "component": {
            "Column": {
              "children": {"explicitList": ["title", "description", "options-list", "divider", "other-section"]}
            }
          }
        },
        {
          "id": "title",
          "component": {
            "Text": {"usageHint": "h2", "text": {"path": "/title"}}
          }
        },
        {
          "id": "description",
          "component": {
            "Text": {"text": {"path": "/description"}}
          }
        },
        {
          "id": "options-list",
          "component": {
            "List": {
              "direction": "vertical",
              "children": {
                "template": {
                  "componentId": "option-button-template",
                  "dataBinding": "/options"
                }
              }
            }
          }
        },
        {
          "id": "option-button-template",
          "component": {
            "Button": {
              "child": "option-label",
              "primary": false,
              "action": {
                "name": "select_option",
                "context": [
                  {"key": "selected", "value": {"path": "/value"}}
                ]
              }
            }
          }
        },
        {
          "id": "option-label",
          "component": {
            "Text": {"text": {"path": "/label"}}
          }
        },
        {
          "id": "divider",
          "component": {"Divider": {}}
        },
        {
          "id": "other-section",
          "component": {
            "Column": {
              "children": {"explicitList": ["other-label", "other-row"]}
            }
          }
        },
        {
          "id": "other-label",
          "component": {
            "Text": {"usageHint": "h5", "text": {"path": "/otherLabel"}}
          }
        },
        {
          "id": "other-row",
          "component": {
            "Row": {
              "children": {"explicitList": ["other-input", "other-submit"]}
            }
          }
        },
        {
          "id": "other-input",
          "weight": 3,
          "component": {
            "TextField": {
              "placeholder": {"path": "/otherPlaceholder"},
              "dataBinding": "/otherText"
            }
          }
        },
        {
          "id": "other-submit",
          "weight": 1,
          "component": {
            "Button": {
              "child": "other-submit-text",
              "primary": true,
              "action": {
                "name": "submit_other",
                "context": [
                  {"key": "selected", "value": {"literalString": "_other"}},
                  {"key": "otherText", "value": {"path": "/otherText"}}
                ]
              }
            }
          }
        },
        {
          "id": "other-submit-text",
          "component": {
            "Text": {"text": {"literalString": "Send"}}
          }
        }
      ]
    }
  },
  {
    "dataModelUpdate": {
      "surfaceId": "choice",
      "path": "/",
      "contents": [
        {"key": "title", "valueString": "Which option do you prefer?"},
        {"key": "description", "valueString": "Select one of the suggested options, or type your own preference below."},
        {
          "key": "options",
          "valueMap": [
            {"key": "opt1", "valueMap": [
              {"key": "label", "valueString": "Option A"},
              {"key": "value", "valueString": "option_a"}
            ]},
            {"key": "opt2", "valueMap": [
              {"key": "label", "valueString": "Option B"},
              {"key": "value", "valueString": "option_b"}
            ]},
            {"key": "opt3", "valueMap": [
              {"key": "label", "valueString": "Option C"},
              {"key": "value", "valueString": "option_c"}
            ]}
          ]
        },
        {"key": "otherLabel", "valueString": "Or tell me what you'd prefer instead:"},
        {"key": "otherPlaceholder", "valueString": "Type your preference or instructions..."},
        {"key": "otherText", "valueString": ""}
      ]
    }
  }
]
