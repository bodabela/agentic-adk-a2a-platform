    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "LLM call latency at p50, p90, p95 and p99 percentiles.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
